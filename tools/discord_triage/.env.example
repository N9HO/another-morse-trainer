# Copy to .env for local runs, or set each as a Fly.io secret (see README).
# NEVER commit a filled-in .env — it contains live credentials.

# --- Discord ---
# Bot token from https://discord.com/developers/applications -> your app -> Bot.
DISCORD_BOT_TOKEN=

# Comma-separated channel IDs to watch. Leave blank to watch every channel
# the bot can see. (Enable Developer Mode in Discord to copy channel IDs.)
WATCH_CHANNEL_IDS=

# "react" = only triage when a maintainer reacts with a trigger emoji (recommended).
# "auto"  = triage every non-bot message in the watched channels.
TRIGGER_MODE=react
# One or more trigger emojis, separated by commas or spaces. Reacting with ANY
# of them triggers a triage, e.g. TRIGGER_EMOJI=🐛,✨,🔧
TRIGGER_EMOJI=🐛

# --- Anthropic ---
ANTHROPIC_API_KEY=
# Default is the most capable model. This is a high-volume, low-complexity task,
# so for lower cost set claude-haiku-4-5 (cheapest) or claude-sonnet-4-6 (mid).
ANTHROPIC_MODEL=claude-opus-4-8

# --- GitHub ---
# Fine-grained PAT with Issues: Read and write on the repo(s) below.
GITHUB_TOKEN=
GITHUB_REPO=n9ho/another-morse-trainer
# Optional: route Android-platform bugs to a separate repo. Leave empty to file
# every platform in GITHUB_REPO (the original behavior). The PAT above must have
# Issues: read/write on this repo too.
GITHUB_REPO_ANDROID=n9ho/another-morse-trainer-android
# Label applied to every issue the bot opens, so they're easy to filter.
TRIAGE_LABEL=from-discord
